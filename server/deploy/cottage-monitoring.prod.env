ENV=production
DB_URL=postgresql+asyncpg://cottage:CHANGE_ME@host.docker.internal:5432/cottage_monitoring
REDIS_URL=redis://host.docker.internal:6379/0
MQTT_HOST=host.docker.internal
MQTT_PORT=1883
MQTT_USE_TLS=false
MQTT_CLIENT_ID=cottage-monitoring-server
MQTT_TOPIC_PREFIX=
LOG_LEVEL=INFO
API_PORT=8321
# Overridden to 0.0.0.0 in systemd (-e) so -p 127.0.0.1:8321:8321 works.
API_HOST=0.0.0.0
