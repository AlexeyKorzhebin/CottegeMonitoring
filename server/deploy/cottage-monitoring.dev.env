ENV=dev
DB_URL=postgresql+asyncpg://cottage:cottage@host.docker.internal:5432/cottage_monitoring_dev
REDIS_URL=redis://host.docker.internal:6379/1
MQTT_HOST=host.docker.internal
MQTT_PORT=1883
MQTT_USE_TLS=false
MQTT_CLIENT_ID=cottage-monitoring-dev
MQTT_TOPIC_PREFIX=dev/
LOG_LEVEL=DEBUG
API_PORT=8322
# Overridden to 0.0.0.0 in systemd (-e) so -p 127.0.0.1:8322:8322 works.
API_HOST=0.0.0.0
