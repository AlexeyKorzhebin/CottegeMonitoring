    {
      "id": 8,
      "type": "timeseries",
      "title": "Loadavg LM (1 / 5 / 15 мин)",
      "datasource": {
        "type": "postgres",
        "uid": "cottage-monitoring-pg"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "time_series",
          "rawSql": "SELECT\n  $__timeGroupAlias(e.ts, $__interval),\n  avg((e.value #>> '{}')::double precision) FILTER (WHERE e.ga = '34/1/6') AS \"load1\",\n  avg((e.value #>> '{}')::double precision) FILTER (WHERE e.ga = '34/1/7') AS \"load5\",\n  avg((e.value #>> '{}')::double precision) FILTER (WHERE e.ga = '34/1/8') AS \"load15\"\nFROM events e\nWHERE e.house_id = 'house'\n  AND e.ga IN ('34/1/6','34/1/7','34/1/8')\n  AND $__timeFilter(e.ts)\nGROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "spanNulls": false,
            "insertNulls": 172800000,
            "lineInterpolation": "linear",
            "thresholdsStyle": {
              "mode": "line+area"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "semi-dark-green",
                "value": null
              },
              {
                "color": "semi-dark-yellow",
                "value": 1.0
              },
              {
                "color": "orange",
                "value": 1.5
              },
              {
                "color": "semi-dark-red",
                "value": 2.0
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "description": "Зелёный <1.0 · жёлтый 1.0–1.5 · оранжевый 1.5–2.0 · красный >2.0. Линия 2.0 — порог алерта load15. Цифры сверху — цвет фона по тем же порогам."
