    {
      "id": 3,
      "type": "table",
      "title": "Батарейки",
      "datasource": {
        "type": "postgres",
        "uid": "cottage-monitoring-pg"
      },
      "gridPos": {
        "h": 14,
        "w": 14,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT\n  CASE\n    WHEN (cs.value #>> '{}')::double precision < 20 THEN '🔴'\n    WHEN (cs.value #>> '{}')::double precision < 50 THEN '🟡'\n    ELSE '🟢'\n  END AS lvl,\n  CASE\n    WHEN o.ga = '33/1/3' THEN 'Серверная'\n    WHEN o.ga = '33/1/6' THEN 'Спальня 1эт'\n    WHEN o.ga = '33/1/9' THEN 'Гостиная'\n    WHEN o.ga = '33/1/12' THEN 'Ванная 1эт'\n    WHEN o.ga = '33/1/15' THEN 'Кухня'\n    WHEN o.ga = '33/1/18' THEN 'Кабинет'\n    WHEN o.ga = '33/1/21' THEN 'Тим'\n    WHEN o.ga = '33/1/24' THEN 'Настя'\n    WHEN o.ga = '33/1/27' THEN 'Холл 2эт'\n    WHEN o.ga = '33/1/30' THEN 'Холл 1эт'\n    WHEN o.ga = '33/1/33' THEN 'Ванная 2эт'\n    WHEN o.ga = '33/1/36' THEN 'Спальня 2эт'\n    WHEN o.ga = '32/7/15' THEN 'PIR sensor 1'\n    ELSE replace(replace(o.name, 'zb_sensor_', ''), '_battery', '')\n  END AS sensor,\n  round((cs.value #>> '{}')::double precision::numeric, 0) AS battery_pct,\n  cs.ts AS updated,\n  o.ga\nFROM objects o\nJOIN current_state cs ON cs.house_id = o.house_id AND replace(cs.ga, '-', '/') = o.ga\nWHERE o.house_id = 'house'\n  AND o.tags LIKE '%battery%'\nORDER BY battery_pct ASC, sensor"
        }
      ],
      "description": "🟢 ≥50% · 🟡 20–49% · 🔴 <20%. Zigbee датчики температуры/влажности + PIR.",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "battery_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "dark-red",
                      "value": null
                    },
                    {
                      "color": "dark-red",
                      "value": 0
                    },
                    {
                      "color": "dark-yellow",
                      "value": 20
                    },
                    {
                      "color": "dark-green",
                      "value": 50
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Нужна замена / контроль (<50%)",
      "datasource": {
        "type": "postgres",
        "uid": "cottage-monitoring-pg"
      },
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 14,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT\n  CASE\n    WHEN (cs.value #>> '{}')::double precision < 20 THEN '🔴'\n    ELSE '🟡'\n  END AS lvl,\n  CASE\n    WHEN o.ga = '33/1/3' THEN 'Серверная'\n    WHEN o.ga = '33/1/6' THEN 'Спальня 1эт'\n    WHEN o.ga = '33/1/9' THEN 'Гостиная'\n    WHEN o.ga = '33/1/12' THEN 'Ванная 1эт'\n    WHEN o.ga = '33/1/15' THEN 'Кухня'\n    WHEN o.ga = '33/1/18' THEN 'Кабинет'\n    WHEN o.ga = '33/1/21' THEN 'Тим'\n    WHEN o.ga = '33/1/24' THEN 'Настя'\n    WHEN o.ga = '33/1/27' THEN 'Холл 2эт'\n    WHEN o.ga = '33/1/30' THEN 'Холл 1эт'\n    WHEN o.ga = '33/1/33' THEN 'Ванная 2эт'\n    WHEN o.ga = '33/1/36' THEN 'Спальня 2эт'\n    WHEN o.ga = '32/7/15' THEN 'PIR sensor 1'\n    ELSE o.name\n  END AS sensor,\n  round((cs.value #>> '{}')::double precision::numeric, 0) AS battery_pct\nFROM objects o\nJOIN current_state cs ON cs.house_id = o.house_id AND replace(cs.ga, '-', '/') = o.ga\nWHERE o.house_id = 'house'\n  AND o.tags LIKE '%battery%'\n  AND (cs.value #>> '{}')::double precision < 50\nORDER BY battery_pct ASC"
        }
      ],
      "description": "Сенсоры с зарядом ниже 50%.",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
