                  "mode": "basic"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Заряд во времени (основные)",
      "datasource": {
        "type": "postgres",
        "uid": "cottage-monitoring-pg"
      },
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 14,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "time_series",
          "rawSql": "SELECT\n  $__timeGroupAlias(e.ts, $__interval),\n  avg((e.value #>> '{}')::double precision) FILTER (WHERE e.ga = '33/1/9') AS \"Гостиная\",\n  avg((e.value #>> '{}')::double precision) FILTER (WHERE e.ga = '33/1/15') AS \"Кухня\",\n  avg((e.value #>> '{}')::double precision) FILTER (WHERE e.ga = '33/1/24') AS \"Настя\",\n  avg((e.value #>> '{}')::double precision) FILTER (WHERE e.ga = '33/1/21') AS \"Тим\",\n  avg((e.value #>> '{}')::double precision) FILTER (WHERE e.ga = '33/1/12') AS \"Ванная 1эт\"\nFROM events e\nWHERE e.house_id = 'house'\n  AND e.ga IN ('33/1/9','33/1/15','33/1/24','33/1/21','33/1/12')\n  AND $__timeFilter(e.ts)\nGROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "spanNulls": false,
            "insertNulls": 172800000,
            "lineInterpolation": "linear"
          },
          "unit": "percent"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "description": "История заряда (часто обновляется редко)."
    }
  ]
