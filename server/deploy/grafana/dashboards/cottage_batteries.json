                      "value": 0
                    },
                    {
                      "color": "dark-yellow",
                      "value": 20
                    },
                    {
                      "color": "dark-green",
                      "value": 50
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
