    {
      "id": 13,
      "type": "timeseries",
      "title": "Total P",
      "datasource": {
        "type": "postgres",
        "uid": "cottage-monitoring-pg"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "time_series",
          "rawSql": "SELECT\n  $__timeGroupAlias(e.ts, $__interval),\n  avg((e.value #>> '{}')::double precision) AS \"Total P\"\nFROM events e\nWHERE e.house_id = 'house' AND e.ga = '32/1/35' AND $__timeFilter(e.ts)\nGROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "spanNulls": false,
            "insertNulls": 172800000,
            "lineInterpolation": "linear"
          },
          "unit": "watt"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
